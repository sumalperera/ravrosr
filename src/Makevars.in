TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libravrosr.a
PKG_LIBS = -L$(LIBDIR) -lravrosr @ADDITIONAL_PKG_LIBS@

all: C_clean

$(SHLIB): $(STATLIB)

CARGOTMP = $(CURDIR)/.cargo

$(STATLIB):
	# Extract vendored deps if tarball exists but vendor dir does not
	if [ -f ./rust/vendor.tar.xz ] && [ ! -d ./rust/vendor ]; then \
		tar xf ./rust/vendor.tar.xz -C ./rust; \
	fi
	# Create .cargo/config.toml for vendored sources if vendor dir exists
	if [ -d ./rust/vendor ]; then \
		mkdir -p ./rust/.cargo && \
		printf '[source.crates-io]\nreplace-with = "vendored-sources"\n\n[source.vendored-sources]\ndirectory = "vendor"\n' > ./rust/.cargo/config.toml; \
	fi
	# Build from the rust directory so cargo finds .cargo/config.toml
	export PATH="$(PATH):$(HOME)/.cargo/bin" && \
	cd ./rust && \
	if [ "$(NOT_CRAN)" != "true" ]; then \
		cargo build --lib --release --offline --target-dir target; \
	else \
		cargo build --lib --release --target-dir target; \
	fi
	if [ "$(NOT_CRAN)" != "true" ]; then \
		rm -Rf $(CARGOTMP) && \
		mkdir -p $(CARGOTMP) && \
		mv $(TARGET_DIR)/release/build $(CARGOTMP)/build; \
	fi

C_clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS)

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) $(TARGET_DIR)
